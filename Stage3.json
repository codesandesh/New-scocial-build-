    {
      "parameters": {
        "jsCode": "// Carry FB record_id forward after Facebook post\nconst fbItem = $('Is Facebook?').first();\nconst record_id = fbItem.json.record_id;\nconst Source_Content_ID = fbItem.json.Source_Content_ID;\nreturn [{ json: { record_id, Source_Content_ID } }];"
      },
