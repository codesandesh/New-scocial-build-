        "jsCode": "// Carry LI record_id forward after LinkedIn post\nconst liItem = $('Group Topic Pair').all().find(i => i.json.platform === 'LinkedIn');\nconst record_id = liItem ? liItem.json.record_id : null;\nconst Source_Content_ID = liItem ? liItem.json.Source_Content_ID : null;\nreturn [{ json: { record_id, Source_Content_ID } }];"
