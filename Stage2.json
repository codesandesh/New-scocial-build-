    {
      "parameters": {
        "jsCode": "const results = [];\nconst rawInputs = $input.all();\nconst sourceItems = $(\"Find Posts to Script\").all();\nconst sourceCount = sourceItems.length;\n\nif (sourceCount === 0) return [];\n\nfor (let i = 0; i < rawInputs.length; i++) {\n  const item = rawInputs[i];\n  let raw = item.json.text || item.json.output || '{}';\n  let parsed = {};\n  try {\n    parsed = JSON.parse(raw);\n  } catch (e) {\n    const match = raw.match(/\\{[^]*\\}/);\n    if (match) { try { parsed = JSON.parse(match[0]); } catch {} }\n  }\n\n  // Identify source record\n  const sourceIndex = i % sourceCount;\n  const sourceRecord = sourceItems[sourceIndex]?.json || {};\n\n  // FORCE CORRECT PLATFORM: Items 0 to sourceCount-1 are LinkedIn, the rest are Facebook\n  const platform = (i < sourceCount) ? 'LinkedIn' : 'Facebook';\n\n  const title = parsed.title || parsed.Name || sourceRecord.Name || 'Untitled Script';\n\n  results.push({\n    json: {\n      Name: title,\n      Source_Content_ID: [sourceRecord.id],\n      Script_Title: title,\n      Target_Platforms: platform,\n      Hook: parsed.hook || '',\n      Main_Content: parsed.body || '',\n      CTA: parsed.cta || '',\n      Status: 'Draft',\n      Created_Date: new Date().toISOString().slice(0, 10)\n    }\n  });\n}\n\nreturn results;"
      },
